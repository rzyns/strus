STRUS_DB_PATH=/absolute/path/to/strus.db
PORT=3457
STRUS_API_URL=http://localhost:3457
ELEVENLABS_API_KEY=              # ElevenLabs API key for TTS generation
GEMINI_API_KEY=                  # Google Gemini API key for image generation
STRUS_MEDIA_DIR=                 # Optional: path to media directory (default: ./media)
STRUS_MEDIA_BASE_URL=            # Optional: base URL for media (default: http://localhost:{PORT}/media)
