{
  "name": "strus",
  "version": "0.9.1",
  "private": true,
  "description": "Polish morphological spaced repetition system",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "concurrently --names api,web --prefix-colors cyan,magenta \"pnpm --filter @strus/api run dev\" \"pnpm --filter @strus/web run dev\"",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:migrate": "pnpm --filter @strus/db run migrate",
    "db:generate": "pnpm --filter @strus/db run generate",
    "version": "bumpp --recursive --commit --tag --push"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/bun": "^1.1.0",
    "bumpp": "^10.4.1",
    "concurrently": "^9.2.1",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.2.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.30.1"
}
