{
  "name": "strus",
  "version": "1.7.4",
  "private": true,
  "description": "Polish morphological spaced repetition system",
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "concurrently --names api,web --prefix-colors cyan,magenta \"bun run --filter @strus/api dev\" \"bun run --filter @strus/web dev\"",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run typecheck",
    "db:migrate": "bun run --filter @strus/db migrate",
    "db:generate": "bun run --filter @strus/db generate",
    "version": "bumpp --recursive --commit --tag --push"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/bun": "^1.1.0",
    "bumpp": "^10.4.1",
    "concurrently": "^9.2.1",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.2.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ]
}
