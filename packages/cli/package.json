{
  "name": "@rzyns/strus-cli",
  "version": "2.0.0-beta.4",
  "description": "Commander.js CLI for strus",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "strus": "./src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "echo 'lint: ok'"
  },
  "dependencies": {
    "@rzyns/strus-api": "workspace:*",
    "@rzyns/strus-core": "workspace:*",
    "commander": "^12.1.0",
    "zod": "^3.23.0",
    "@rzyns/strus-config": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
