{
  "name": "@strus/api",
  "version": "1.12.1",
  "private": true,
  "description": "Elysia + oRPC HTTP server for strus",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "generate:spec": "bun run scripts/generate-spec.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "echo 'lint: ok'"
  },
  "dependencies": {
    "@elysiajs/opentelemetry": "^1.4.10",
    "@elysiajs/static": "^1.4.7",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@orpc/openapi": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@orpc/zod": "^1.13.5",
    "@strus/config": "workspace:*",
    "@strus/core": "workspace:*",
    "@strus/db": "workspace:*",
    "@strus/morph": "workspace:*",
    "@types/mustache": "^4.2.6",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.25",
    "mustache": "^4.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.7.0"
  }
}
