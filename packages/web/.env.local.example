# Browser-side OTel — copy to .env.local and adjust for your setup
#
# Dev (Vite proxies /otlp → http://localhost:4318):
#   VITE_OTEL_OTLP_ENDPOINT=/otlp
#
# Production (direct to collector, same-origin or CORS-enabled):
#   VITE_OTEL_OTLP_ENDPOINT=https://your-collector.homelab/otlp
#
# Leave unset to disable tracing entirely (zero overhead).
VITE_OTEL_OTLP_ENDPOINT=/otlp
VITE_OTEL_SERVICE_NAME=strus-web
